<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 顶部导航栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="← 返回"
                android:textSize="13sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="设置"
                android:textSize="26sp"
                android:textColor="@color/md_on_background"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="-0.02" />

            <View
                android:layout_width="48dp"
                android:layout_height="1dp" />

        </LinearLayout>

        <!-- 自动答题设置（无障碍模式） -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md_surface_variant"
            app:strokeColor="@color/md_outline_variant"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="自动答题（无障碍）"
                            android:textSize="18sp"
                            android:textColor="@color/md_on_surface"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="通过无障碍服务自动识别屏幕并点击"
                            android:textSize="13sp"
                            android:textColor="@color/md_on_surface_variant"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAutoAnswer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="× 无障碍权限未开启"
                    android:textSize="13sp"
                    android:textColor="@color/md_error"
                    android:layout_marginTop="12dp"
                    android:padding="10dp"
                    android:background="#1AF44336"
                    android:gravity="center_vertical"
                    android:drawablePadding="6dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Shizuku 自动答题模式 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md_surface_variant"
            app:strokeColor="@color/md_outline_variant"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="自动答题（Shizuku）"
                            android:textSize="18sp"
                            android:textColor="@color/md_on_surface"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="通过 Shizuku 提升权限模拟点击（无需无障碍）"
                            android:textSize="13sp"
                            android:textColor="@color/md_on_surface_variant"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchShizuku"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvShizukuStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="× Shizuku 未启用"
                    android:textSize="13sp"
                    android:textColor="@color/md_error"
                    android:layout_marginTop="12dp"
                    android:padding="10dp"
                    android:background="#1AF44336"
                    android:gravity="center_vertical"
                    android:drawablePadding="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShizukuConfig"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:text="答题配置：共 10 题，最低 30 秒"
                    android:textSize="13sp"
                    android:enabled="false" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 使用说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md_surface_variant"
            app:strokeColor="@color/md_outline_variant"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📖 使用说明"
                    android:textSize="18sp"
                    android:textColor="@color/md_on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. 开启「自动答题」开关\n\n2. 在弹出的对话框中点击「去设置」\n\n3. 在无障碍设置页面中找到「自动答题服务」\n\n4. 开启该服务并确认\n\n5. 返回应用后，开关会自动变为开启状态\n\n6. 进入答题界面后，应用会自动开始识别和答题"
                    android:textSize="14sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 隐私说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md_surface_variant"
            app:strokeColor="@color/md_outline_variant"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒 隐私说明"
                    android:textSize="18sp"
                    android:textColor="@color/md_on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="本应用所有功能均在本地执行，不会收集、存储或上传您的任何个人信息。题库数据仅存储在您的设备本地。请放心使用。"
                    android:textSize="14sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 检测更新 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md_surface_variant"
            app:strokeColor="@color/md_outline_variant"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔄 检测更新"
                    android:textSize="18sp"
                    android:textColor="@color/md_on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="版本 1.1.1"
                    android:textSize="13sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvUpdateStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="点击下方按钮检查更新"
                    android:textSize="13sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:padding="10dp"
                    android:background="#1A6750A4"
                    android:gravity="center_vertical"
                    android:drawablePadding="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCheckUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:text="检查更新"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
