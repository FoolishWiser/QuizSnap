<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 顶栏标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="题库助手"
                android:textSize="28sp"
                android:textColor="@color/md_on_background"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="设置"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- AI 提示词卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_primary_container"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 提示词区域标题 + DeepSeek 专家模式提示 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI 提示词"
                        android:textSize="18sp"
                        android:textColor="@color/md_on_primary_container"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="💡 建议使用 DeepSeek 专家模式获得最佳结果"
                        android:textSize="13sp"
                        android:textColor="@color/md_on_primary_container"
                        android:alpha="0.8"
                        android:background="@color/deepseek_badge_bg"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:gravity="center_vertical"
                        android:drawablePadding="6dp"
                        android:letterSpacing="0.01" />

                </LinearLayout>

                <!-- 提示词正文 -->
                <TextView
                    android:id="@+id/tvAiPrompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textSize="13sp"
                    android:textColor="@color/md_on_primary_container"
                    android:alpha="0.85"
                    android:lineSpacingExtra="4dp"
                    android:padding="12dp"
                    android:background="@color/md_surface"
                    android:backgroundTint="#B3FFFFFF"
                    android:maxLines="8"
                    android:scrollbars="vertical" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopyPrompt"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:text="复制提示词"
                    android:textSize="13sp"
                    app:icon="@android:drawable/ic_menu_set_as"
                    app:iconGravity="textStart"
                    app:iconSize="16dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 导入AI结果按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInputText"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="✏️ 手动输入"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPasteClipboard"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="📋 获取剪贴板"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- 导航按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewHistory"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📚 我的题库"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartFloating"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="🪟 启动悬浮窗"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- 已加载题目 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/md_surface_variant"
            app:strokeColor="@color/md_outline_variant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="已加载题目"
                    android:textSize="16sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="360dp"
                    android:scrollbars="vertical"
                    android:clipToPadding="false"
                    android:paddingTop="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
